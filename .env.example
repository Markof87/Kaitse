# App
APP_NAME=Kaitse API
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# API
API_V1_PREFIX=/api/v1

# Database — async (FastAPI runtime)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/kaitse

# Database — sync (Alembic migrations)
DATABASE_URL_SYNC=postgresql+psycopg://user:password@localhost:5432/kaitse